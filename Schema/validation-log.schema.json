{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/validation-log.schema.json",
  "title": "Validation Log",
  "type": "object",
  "additionalProperties": false,
  "required": ["form_name", "error_code", "created_at"],
  "properties": {
    "form_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "field_name": {
      "type": ["string", "null"],
      "maxLength": 80
    },
    "error_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
