{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/address.schema.json",
  "title": "Address Form",
  "type": "object",
  "additionalProperties": false,
  "required": ["country", "state_province", "postal_code", "street", "city"],
  "properties": {
    "country": {
      "type": "string",
      "enum": ["US", "CA", "GB"]
    },
    "state_province": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "postal_code": {
      "type": "string",
      "minLength": 3,
      "maxLength": 16
    },
    "street": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "city": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    }
  }
}
